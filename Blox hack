local function StartAutoFarm()
    if State.AutoFarm then return end
    State.AutoFarm = true
    Notify("Auto Farm Started")
    
    Threads.AutoFarm = task.spawn(function()
        while State.AutoFarm do
            local target = GetNearestNPC(Settings.FarmRadius, true)
            if target then
                AttackTarget(target)
            end
            wait(0.3)
        end
    end)
end

local function StartAutoV4()
    if State.AutoV4 then return end
    State.AutoV4 = true
    Notify("Auto V4 Started")
    
    Threads.AutoV4 = task.spawn(function()
        while State.AutoV4 do
            local npc = workspace:FindFirstChild("AwekeningNPC") or workspace:FindFirstChild("RaceNPC") or workspace:FindFirstChild("V4NPC")
            if npc and npc:FindFirstChild("HumanoidRootPart") then
                Teleport(npc.HumanoidRootPart.Position + Vector3.new(0, 3, 0))
                wait(0.3)
                FireClick(npc:FindFirstChildOfClass("ClickDetector"))
                for _, v in pairs(npc:GetDescendants()) do
                    if v:IsA("ClickDetector") then FireClick(v) end
                end
            end
            
            for _, v in pairs(workspace:GetDescendants()) do
                if v:IsA("Model") and (string.find(string.lower(v.Name), "v4") or string.find(string.lower(v.Name), "awaken") or string.find(string.lower(v.Name), "race")) then
                    if v:FindFirstChild("HumanoidRootPart") then
                        Teleport(v.HumanoidRootPart.Position + Vector3.new(0, 3, 0))
                        wait(0.2)
                        FireClick(v:FindFirstChildOfClass("ClickDetector"))
                        for _, child in pairs(v:GetDescendants()) do
                            if child:IsA("ClickDetector") then FireClick(child) end
                        end
                    end
                end
            end
            wait(Settings.V4Delay)
        end
    end)
end

local function StartFindLevi()
    if State.FindLevi then return end
    State.FindLevi = true
    Notify("Searching Leviathan")
    
    Threads.FindLevi = task.spawn(function()
        while State.FindLevi do
            local found = false
            for _, v in pairs(workspace:GetDescendants()) do
                if v:IsA("Model") and (string.find(string.lower(v.Name), "levi") or string.find(string.lower(v.Name), "leviathan")) then
                    if v:FindFirstChild("HumanoidRootPart") then
                        Teleport(v.HumanoidRootPart.Position + Vector3.new(0, 10, 0))
                        Notify("Leviathan Found!", 5)
                        found = true
                        break
                    end
                end
            end
            
            if not found then
                local boat = workspace:FindFirstChild("Boat") or workspace:FindFirstChild("Ship") or workspace:FindFirstChild("SeaBoat")
                if boat and boat:FindFirstChild("HumanoidRootPart") then
                    Teleport(boat.HumanoidRootPart.Position + Vector3.new(0, 5, 0))
                end
                wait(Settings.LeviSearchInterval)
            else
                wait(30)
            end
        end
    end)
end

